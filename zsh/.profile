
export EDITOR='nvim'
export PAGER=less
export PATH=~/.scripts:~/bin:~/.local/bin:$PATH
export LC_ALL=en_US.UTF-8
export LS_COLORS='di=30:fi=30:ln=30'

export GOPATH=~/.go
export GO111MODULE=on
# or https://mirrors.aliyun.com/goproxy/
export GOPROXY=https://mirrors.cloud.tencent.com/go/

# may be used by
# * i3-sensible-terminal
# * xdg-open
# * rofi-sensible-terminal
export TERMINAL=st

# may be used by
# * i3-sensible-browser
# * xdg-open
# * tmux-open
export BROWSER=vivaldi-stable

export QT_SCALE_FACTOR=1.3
# on 1920x1080 laptop
export QT_FONT_DPI=96
